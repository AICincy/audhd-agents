{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "provider": {
      "type": "string",
      "enum": ["anthropic", "openai", "google"],
      "description": "Target LLM provider."
    },
    "model_id": {
      "type": "string",
      "description": "Model identifier from agent registry (e.g., C-OP46, G-PRO, O-54)."
    },
    "payload": {
      "type": "object",
      "description": "Provider-normalized request payload.",
      "properties": {
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["system", "user", "assistant"] },
              "content": { "type": "string" }
            },
            "required": ["role", "content"]
          }
        },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 }
      },
      "required": ["messages"]
    },
    "options": {
      "type": "object",
      "properties": {
        "timeout_ms": { "type": "integer", "default": 60000 },
        "retry_count": { "type": "integer", "default": 3 },
        "fallback_chain": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered list of fallback model IDs."
        }
      }
    }
  },
  "required": ["provider", "model_id", "payload"]
}
