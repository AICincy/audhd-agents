  "properties": {
    "input_text": {
      "type": "string",
      "description": "Feedback data (survey responses, support tickets, reviews, interview notes)"
    },
    "source": {
      "type": "string",
      "description": "Feedback channel",
      "enum": ["survey", "support-tickets", "app-reviews", "interviews", "social", "mixed"]
    },
    "time_period": {
