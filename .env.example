# audhd-agents environment configuration
# Copy to .env and fill in your actual keys
# NEVER commit .env to version control

# ============================================================
# REQUIRED: Provider API Keys (read by adapters via config.yaml)
# ============================================================

# OpenAI (GPT-5.4, GPT-5.3, GPT-5.4 Pro, GPT-5.3 Codex, GPT Max, o4-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini 2.5 Pro via Gemini Developer API
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_PROJECT_ID=YOUR_PROJECT_ID_HERE

# Vertex AI Gemini 2.5 Pro support
# Set to true to force Vertex AI. If omitted, the adapter auto-selects Vertex AI
# when a Vertex-specific credential is present.
GOOGLE_GENAI_USE_VERTEXAI=false

# Vertex AI Express Mode (API key auth)
VERTEX_API_KEY=

# Vertex AI Standard Mode (ADC / service account auth)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
VERTEX_SERVICE_ACCOUNT=
VERTEX_SERVICE_ACCOUNT_FILE=
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================================
# WEBHOOK CONFIGURATION
# ============================================================

# REQUIRED for webhook endpoints. HMAC-SHA256 signing secret.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
NOTION_WEBHOOK_SECRET=

# ============================================================
# API AUTHENTICATION
# ============================================================

# Comma-separated API keys for /execute endpoint auth.
# If empty, auth is disabled (dev mode only).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUDHD_API_KEYS=

# ============================================================
# RUNTIME SERVICE CONTRACT (local development only)
# ============================================================

# The production runtime reads these values from Cloud Run env vars.
# Keep .env local-only; do not use repo .env files in deployed environments.
APP_ENV=staging
REQUIRED_PROVIDERS=openai,google
LOG_LEVEL=INFO

# ============================================================
# VS CODE EXTENSIONS
# ============================================================

# OpenAI Codex Extension for VS Code
OPENAI_CODEX_API_KEY=your_openai_codex_api_key_here

# ============================================================
# OPTIONAL: Infrastructure & Monitoring
# ============================================================

# GitHub (repo access for CI/CD)
GITHUB_PAT=

# Weights & Biases (experiment tracking)
WANDB_API_KEY=

# Context7 (context management)
CONTEXT7_API_KEY=

# Legacy placeholder kept for compatibility. Prefer the vars above.
# VERTEX_SERVICE_ACCOUNT=
